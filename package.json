{
  "name": "read-html",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "node fixtures/generate.mjs",
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build --config vite.config.single.ts",
    "preview": "vite preview",
    "analyze": "vite build --mode analyze",
    "smoke": "node scripts/smoke.mjs",
    "size-check": "node scripts/size-check.mjs",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run knip && npm run test:unit && npm run vendor-check",
    "typecheck": "svelte-check --fail-on-warnings && tsc -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test:unit": "vitest run",
    "vendor-check": "node scripts/vendor-check.mjs",
    "test:e2e": "playwright test",
    "test:e2e:webkit": "sh scripts/e2e-webkit.sh",
    "test:e2e:update": "sh scripts/update-snapshots.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10"
  }
}
